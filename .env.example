# ─── FIREBASE ───────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── WHATSAPP (Meta Cloud API — server-side only, NO VITE_ prefix) ──────────
WHATSAPP_TOKEN=your_permanent_system_user_token
WHATSAPP_PHONE_ID=your_phone_number_id

# ─── WEB PUSH / PWA NOTIFICATIONS ───────────────────────────────────────────
# Generate once with: node generate-vapid-keys.js
# VITE_VAPID_PUBLIC_KEY is used in the browser (safe to expose)
# VAPID_PRIVATE_KEY is server-only — NEVER put in VITE_ variable
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:your-email@gmail.com

# ─── SUPER ADMIN ─────────────────────────────────────────────────────────────
# Change BOTH of these before deploying to production
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=QNow@2024!

# ─── APP URL ─────────────────────────────────────────────────────────────────
VITE_APP_URL=https://qnow-chi.vercel.app
